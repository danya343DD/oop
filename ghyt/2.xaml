<Window x:Class="KeyboardTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клавиатурный тренажёр" Height="600" Width="800"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Focusable="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Статистика -->
            <RowDefinition Height="Auto"/>
            <!-- Настройки -->
            <RowDefinition Height="Auto"/>
            <!-- Задание -->
            <RowDefinition Height="Auto"/>
            <!-- Ввод пользователя -->
            <RowDefinition Height="*"/>
            <!-- Клавиатура -->
        </Grid.RowDefinitions>

        <!-- Статистика -->
        <Border Grid.Row="0" Background="#F5F5F5" 
                Padding="10" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Скорость: " FontSize="16"/>
                <TextBlock x:Name="SpeedText" Text="0 зн/мин" 
                           FontSize="16" FontWeight="Bold"/>
                <TextBlock Text=" | Ошибки: " FontSize="16" Margin="20,0,0,0"/>
                <TextBlock x:Name="ErrorsText" Text="0" 
                           FontSize="16" FontWeight="Bold" Foreground="Red"/>
            </StackPanel>
        </Border>

        <!-- Настройки -->
        <Border Grid.Row="1" Padding="10" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Сложность:" VerticalAlignment="Center"/>
                <Slider x:Name="ComplexitySlider" Width="150" 
                        Minimum="5" Maximum="30" Value="15"
                        Margin="10,0"/>
                <TextBlock x:Name="ComplexityValue" Text="15" 
                           VerticalAlignment="Center" Width="30"/>
                <CheckBox x:Name="CaseSensitive" Content="Учитывать регистр"
                          Margin="20,0,0,0" VerticalAlignment="Center"/>
                <Button x:Name="StartButton" Content="Start" 
                        Width="80" Margin="20,0,0,0"
                        Click="StartButton_Click"/>
                <Button x:Name="StopButton" Content="Stop" 
                        Width="80" Margin="5,0,0,0" IsEnabled="False"
                        Click="StopButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Задание -->
        <Border Grid.Row="2" BorderBrush="Gray" 
                BorderThickness="1" Padding="10" Margin="0,0,0,5">
            <TextBlock x:Name="TargetText" FontSize="24" 
                       FontFamily="Consolas" TextWrapping="Wrap"
                       Text="Нажмите Start"/>
        </Border>

        <!-- Ввод пользователя -->
        <Border Grid.Row="3" BorderBrush="Blue" 
                BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <TextBlock x:Name="UserInputText" FontSize="24" 
                       FontFamily="Consolas" Text=""/>
        </Border>

        <!-- Клавиатура -->
        <Border Grid.Row="4" Background="#E8E8E8" 
                Padding="10" CornerRadius="5">
            <StackPanel x:Name="KeyboardPanel"/>
        </Border>
    </Grid>
</Window>