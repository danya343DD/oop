<Window x:Class="Questionnaire.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анкета пользователя" Height="550" Width="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="АНКЕТА" 
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10"/>

        <!-- ФИО -->
        <TextBlock Grid.Row="1" Text="ФИО:" FontWeight="Bold" Margin="0,5,0,2"/>
        <TextBox x:Name="FullNameBox" Grid.Row="2" 
                 Margin="0,0,0,8" Height="25"/>

        <!-- Возраст -->
        <TextBlock Grid.Row="3" Text="Возраст:" FontWeight="Bold" Margin="0,5,0,2"/>
        <TextBox x:Name="AgeBox" Grid.Row="4" 
                 Margin="0,0,0,8" Height="25"
                 PreviewTextInput="AgeBox_PreviewTextInput"/>

        <!-- Пол -->
        <TextBlock Grid.Row="5" Text="Пол:" FontWeight="Bold" Margin="0,5,0,2"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,8">
            <RadioButton x:Name="MaleRadio" Content="Мужской" 
                         GroupName="Gender" Margin="0,0,20,0"/>
            <RadioButton x:Name="FemaleRadio" Content="Женский" 
                         GroupName="Gender"/>
        </StackPanel>

        <!-- Образование -->
        <TextBlock Grid.Row="7" Text="Образование:" FontWeight="Bold" Margin="0,5,0,2"/>
        <ComboBox x:Name="EducationCombo" Grid.Row="8" 
                  Margin="0,0,0,8" Height="25">
            <ComboBoxItem Content="Среднее"/>
            <ComboBoxItem Content="Среднее специальное"/>
            <ComboBoxItem Content="Неоконченное высшее"/>
            <ComboBoxItem Content="Высшее"/>
            <ComboBoxItem Content="Учёная степень"/>
        </ComboBox>

        <!-- Хобби -->
        <TextBlock Grid.Row="9" Text="Хобби:" FontWeight="Bold" Margin="0,5,0,2"/>
        <StackPanel Grid.Row="10" Margin="0,0,0,10">
            <CheckBox x:Name="SportCheck" Content="Спорт" Margin="0,2,0,2"/>
            <CheckBox x:Name="MusicCheck" Content="Музыка" Margin="0,2,0,2"/>
            <CheckBox x:Name="ReadingCheck" Content="Чтение" Margin="0,2,0,2"/>
            <CheckBox x:Name="TravelCheck" Content="Путешествия" Margin="0,2,0,2"/>
            <CheckBox x:Name="ProgrammingCheck" Content="Программирование" Margin="0,2,0,2"/>
        </StackPanel>

        <!-- Кнопка -->
        <Button Grid.Row="11" Content="Показать результат" 
                Height="35" Margin="0,5,0,5"
                Click="ShowResultButton_Click"
                Background="#4CAF50" Foreground="White"
                FontSize="14"/>
    </Grid>
</Window>